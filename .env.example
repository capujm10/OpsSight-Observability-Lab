OPSIGHT_ENVIRONMENT=local
OPSIGHT_LOG_LEVEL=INFO
OPSIGHT_OTEL_ENABLED=true
OPSIGHT_OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317
OPSIGHT_DEPENDENCY_BASE_LATENCY_MS=80
OPSIGHT_DEPENDENCY_FAILURE_RATE=0.02
OPSIGHT_LATENCY_SIMULATION_MS=1500

# Local-first AI RCA configuration. Use rule_based for deterministic demos without API keys.
AI_PROVIDER=rule_based
AI_MODEL=llama3.2
AI_BASE_URL=http://host.docker.internal:11434
AI_API_KEY=
AI_TIMEOUT_SECONDS=30
AI_MAX_INPUT_CHARS=12000
AI_MAX_OUTPUT_TOKENS=800
AI_RCA_ARTIFACT_DIR=artifacts/ai-rca
