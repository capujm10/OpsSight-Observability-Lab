{
  "uid": "opsight-incident-investigation",
  "title": "OpsSight Incident Investigation",
  "tags": ["opsight", "incident-response", "troubleshooting"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {"from": "now-1h", "to": "now"},
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {"type": "loki", "uid": "loki"},
        "enable": true,
        "expr": "{service=~\"opsight-api|payment-gateway\"} | json | incident_stage=\"incident_start\"",
        "iconColor": "red",
        "name": "Incident start",
        "textFormat": "{{message}}",
        "titleFormat": "Incident start"
      },
      {
        "datasource": {"type": "loki", "uid": "loki"},
        "enable": true,
        "expr": "{service=~\"opsight-api|payment-gateway\"} | json | incident_stage=\"mitigation_deployed\"",
        "iconColor": "orange",
        "name": "Mitigation deployed",
        "textFormat": "{{message}}",
        "titleFormat": "Mitigation deployed"
      },
      {
        "datasource": {"type": "loki", "uid": "loki"},
        "enable": true,
        "expr": "{service=~\"opsight-api|payment-gateway\"} | json | incident_stage=\"recovery_confirmed\"",
        "iconColor": "green",
        "name": "Recovery confirmed",
        "textFormat": "{{message}}",
        "titleFormat": "Recovery confirmed"
      }
    ]
  },
  "templating": {
    "list": [
      {"name": "route", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(opsight_http_requests_total, route)", "refresh": 2, "includeAll": true, "current": {"text": "All", "value": "$__all"}},
      {"name": "severity", "type": "custom", "query": "ERROR,WARNING,INFO", "includeAll": true, "current": {"text": "All", "value": "$__all"}}
    ]
  },
  "panels": [
    {"id": 1, "type": "timeseries", "title": "Latency Spikes by Route", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 0, "y": 0, "w": 12, "h": 7}, "targets": [{"refId": "A", "expr": "histogram_quantile(0.95, sum(rate(opsight_http_request_duration_seconds_bucket{route=~\"$route\"}[5m])) by (le, route))", "legendFormat": "{{route}}"}], "fieldConfig": {"defaults": {"unit": "s"}}},
    {"id": 2, "type": "timeseries", "title": "5xx and Dependency Failures", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 12, "y": 0, "w": 12, "h": 7}, "targets": [{"refId": "5xx", "expr": "sum(rate(opsight_http_requests_total{status_code=~\"5..\"}[5m]))"}, {"refId": "dependency", "expr": "sum(rate(opsight_dependency_failures_total[5m]))"}], "fieldConfig": {"defaults": {"unit": "ops"}}},
    {"id": 3, "type": "logs", "title": "Live Structured Logs", "datasource": {"type": "loki", "uid": "loki"}, "gridPos": {"x": 0, "y": 7, "w": 12, "h": 9}, "targets": [{"refId": "A", "expr": "{service=\"opsight-api\"} | json | severity=~\"$severity\""}], "options": {"showTime": true, "showLabels": true, "dedupStrategy": "none"}},
    {"id": 4, "type": "logs", "title": "Error Logs with Correlation IDs", "datasource": {"type": "loki", "uid": "loki"}, "gridPos": {"x": 12, "y": 7, "w": 12, "h": 9}, "targets": [{"refId": "A", "expr": "{service=\"opsight-api\",severity=\"ERROR\"} | json | line_format \"trace={{.trace_id}} correlation={{.correlation_id}} path={{.path}} msg={{.message}}\""}]},
    {"id": 5, "type": "table", "title": "Troubleshooting Drilldown: Worst Routes", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 0, "y": 16, "w": 8, "h": 8}, "targets": [{"refId": "A", "expr": "topk(10, sum(rate(opsight_http_requests_total{status_code=~\"5..\"}[15m])) by (route, status_code))", "format": "table", "instant": true}]},
    {"id": 6, "type": "table", "title": "Dependency Operations", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 8, "y": 16, "w": 8, "h": 8}, "targets": [{"refId": "A", "expr": "sum(rate(opsight_dependency_latency_seconds_count[15m])) by (dependency, operation, outcome)", "format": "table", "instant": true}]},
    {"id": 7, "type": "traces", "title": "Recent Traces", "datasource": {"type": "tempo", "uid": "tempo"}, "gridPos": {"x": 16, "y": 16, "w": 8, "h": 8}, "targets": [{"refId": "A", "queryType": "traceql", "query": "{ resource.service.name = \"opsight-api\" }"}]},
    {"id": 8, "type": "text", "title": "Incident Timeline View", "gridPos": {"x": 0, "y": 24, "w": 24, "h": 5}, "options": {"mode": "markdown", "content": "1. Detect alert from p95 latency, 5xx, readiness, or dependency degradation.\\n2. Scope blast radius by route, status_code, and active requests.\\n3. Query Loki for severity=ERROR/WARNING and copy trace_id.\\n4. Open the trace in Tempo and inspect dependency spans.\\n5. Confirm mitigation by watching request rate, error rate, p95 latency, and readiness recover."}}
  ]
}
