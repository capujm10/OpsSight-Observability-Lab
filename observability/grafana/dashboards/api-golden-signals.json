{
  "uid": "opsight-api-golden-signals",
  "title": "OpsSight API Golden Signals",
  "tags": ["opsight", "sre", "golden-signals"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "panels": [
    {"id": 1, "type": "stat", "title": "Service Availability", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4}, "targets": [{"refId": "A", "expr": "avg(up{job=\"opsight-api\"})"}], "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"steps": [{"color": "red"}, {"color": "green", "value": 0.99}]}}}},
    {"id": 2, "type": "stat", "title": "Request Rate", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4}, "targets": [{"refId": "A", "expr": "sum(rate(opsight_http_requests_total[5m]))"}], "fieldConfig": {"defaults": {"unit": "reqps"}}},
    {"id": 3, "type": "stat", "title": "5xx Error Rate", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4}, "targets": [{"refId": "A", "expr": "sum(rate(opsight_http_requests_total{status_code=~\"5..\"}[5m]))"}], "fieldConfig": {"defaults": {"unit": "reqps", "thresholds": {"steps": [{"color": "green"}, {"color": "orange", "value": 0.01}, {"color": "red", "value": 0.05}]}}}},
    {"id": 4, "type": "stat", "title": "Active Requests", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4}, "targets": [{"refId": "A", "expr": "sum(opsight_http_active_requests)"}]},
    {"id": 5, "type": "timeseries", "title": "Latency p50 / p95 / p99", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8}, "targets": [{"refId": "p50", "expr": "histogram_quantile(0.50, sum(rate(opsight_http_request_duration_seconds_bucket[5m])) by (le))"}, {"refId": "p95", "expr": "histogram_quantile(0.95, sum(rate(opsight_http_request_duration_seconds_bucket[5m])) by (le))"}, {"refId": "p99", "expr": "histogram_quantile(0.99, sum(rate(opsight_http_request_duration_seconds_bucket[5m])) by (le))"}], "fieldConfig": {"defaults": {"unit": "s"}}},
    {"id": 6, "type": "timeseries", "title": "Endpoint Throughput", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8}, "targets": [{"refId": "A", "expr": "sum(rate(opsight_http_requests_total[5m])) by (route, method)", "legendFormat": "{{method}} {{route}}"}], "fieldConfig": {"defaults": {"unit": "reqps"}}},
    {"id": 7, "type": "barchart", "title": "HTTP Status Code Distribution", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 0, "y": 12, "w": 8, "h": 7}, "targets": [{"refId": "A", "expr": "sum(increase(opsight_http_requests_total[30m])) by (status_code)", "legendFormat": "{{status_code}}"}]},
    {"id": 8, "type": "table", "title": "Slowest Endpoints p95", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 8, "y": 12, "w": 8, "h": 7}, "targets": [{"refId": "A", "expr": "topk(10, histogram_quantile(0.95, sum(rate(opsight_http_request_duration_seconds_bucket[5m])) by (le, route)))", "format": "table", "instant": true}]},
    {"id": 9, "type": "timeseries", "title": "Dependency Latency p95", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"x": 16, "y": 12, "w": 8, "h": 7}, "targets": [{"refId": "A", "expr": "histogram_quantile(0.95, sum(rate(opsight_dependency_latency_seconds_bucket[5m])) by (le, dependency, operation))", "legendFormat": "{{dependency}} {{operation}}"}], "fieldConfig": {"defaults": {"unit": "s"}}},
    {"id": 10, "type": "logs", "title": "Recent Incidents", "datasource": {"type": "loki", "uid": "loki"}, "gridPos": {"x": 0, "y": 19, "w": 24, "h": 8}, "targets": [{"refId": "A", "expr": "{service=\"opsight-api\"} | json | severity =~ \"ERROR|WARNING\""}]}
  ]
}
