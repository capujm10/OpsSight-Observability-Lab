{
  "uid": "opsight-kubernetes-operations",
  "title": "OpsSight Kubernetes Operations",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["opsight", "kubernetes", "k3d", "k3s"],
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {"id": 1, "type": "stat", "title": "kube-state-metrics Up", "gridPos": {"h": 4, "w": 5, "x": 0, "y": 0}, "targets": [{"expr": "up{job=\"kubernetes-kube-state-metrics\"}", "refId": "A"}]},
    {"id": 2, "type": "stat", "title": "Ready Nodes", "gridPos": {"h": 4, "w": 5, "x": 5, "y": 0}, "targets": [{"expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})", "refId": "A"}]},
    {"id": 3, "type": "timeseries", "title": "Pod Restarts", "gridPos": {"h": 8, "w": 7, "x": 10, "y": 0}, "targets": [{"expr": "sum by (namespace, pod) (increase(kube_pod_container_status_restarts_total[10m]))", "legendFormat": "{{namespace}}/{{pod}}", "refId": "A"}]},
    {"id": 4, "type": "table", "title": "CrashLoopBackOff", "gridPos": {"h": 8, "w": 7, "x": 17, "y": 0}, "targets": [{"expr": "kube_pod_container_status_waiting_reason{reason=\"CrashLoopBackOff\"}", "format": "table", "instant": true, "refId": "A"}]},
    {"id": 5, "type": "timeseries", "title": "Node Pressure", "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8}, "targets": [{"expr": "kube_node_status_condition{condition=~\"MemoryPressure|DiskPressure|PIDPressure\",status=\"true\"}", "legendFormat": "{{node}} {{condition}}", "refId": "A"}]},
    {"id": 6, "type": "timeseries", "title": "Namespace Pod Count", "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8}, "targets": [{"expr": "sum by (namespace) (kube_pod_info)", "legendFormat": "{{namespace}}", "refId": "A"}]},
    {"id": 7, "type": "timeseries", "title": "Cluster CPU and Memory Requests", "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8}, "targets": [{"expr": "sum(kube_pod_container_resource_requests{resource=\"cpu\"})", "legendFormat": "cpu requests", "refId": "A"}, {"expr": "sum(kube_pod_container_resource_requests{resource=\"memory\"})", "legendFormat": "memory requests", "refId": "B"}]},
    {"id": 8, "type": "timeseries", "title": "API Server Health", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}, "targets": [{"expr": "up{job=~\"kubernetes-apiservers|apiserver|kubernetes\"}", "legendFormat": "{{job}} {{instance}}", "refId": "A"}]},
    {"id": 9, "type": "timeseries", "title": "Ingress Traffic", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}, "targets": [{"expr": "sum by (ingress, namespace) (rate(nginx_ingress_controller_requests[5m]))", "legendFormat": "{{namespace}}/{{ingress}}", "refId": "A"}]}
  ]
}
